{
  "name": "@gremius/sdk",
  "version": "0.2.0",
  "description": "GremiusCMS Universal SDK — CRUD in 3 lines. Edge-ready. Type-safe.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "gremius",
    "cms",
    "baas",
    "sdk",
    "typescript",
    "edge",
    "serverless"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
