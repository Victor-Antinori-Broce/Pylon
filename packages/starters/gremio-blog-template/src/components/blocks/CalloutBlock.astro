---
/**
 * CalloutBlock.astro — Info/warning/tip highlighted box
 */
interface Props {
  title?: string;
  content: string;
  variant?: "info" | "warning" | "success" | "danger" | "tip";
}

const { title, content, variant = "info" } = Astro.props;

const variantStyles: Record<string, { bg: string; border: string; icon: string; titleColor: string }> = {
  info:    { bg: "bg-blue-500/5",   border: "border-blue-500/20",   icon: "ℹ️", titleColor: "text-blue-400"   },
  warning: { bg: "bg-yellow-500/5", border: "border-yellow-500/20", icon: "⚠️", titleColor: "text-yellow-400" },
  success: { bg: "bg-green-500/5",  border: "border-green-500/20",  icon: "✅", titleColor: "text-green-400"  },
  danger:  { bg: "bg-red-500/5",    border: "border-red-500/20",    icon: "🚨", titleColor: "text-red-400"    },
  tip:     { bg: "bg-purple-500/5", border: "border-purple-500/20", icon: "💡", titleColor: "text-purple-400" },
};

const s = variantStyles[variant] || variantStyles.info;
---

<aside class={`rounded-xl border ${s.border} ${s.bg} px-5 py-4`}>
  <div class="flex items-start gap-3">
    <span class="text-lg shrink-0 mt-0.5">{s.icon}</span>
    <div>
      {title && (
        <p class={`text-sm font-semibold ${s.titleColor} mb-1`}>{title}</p>
      )}
      <p class="text-sm text-zinc-300 leading-relaxed">{content}</p>
    </div>
  </div>
</aside>
