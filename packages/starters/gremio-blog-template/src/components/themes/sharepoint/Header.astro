---
/**
 * SharePoint-Style Header
 * A faithful recreation of the Office 365 / SharePoint top bar.
 */

interface Props {
    siteName?: string;
    userAvatar?: string;
}

const {
    siteName = "Gremius Intranet",
    userAvatar = "https://ui-avatars.com/api/?name=User&background=random",
} = Astro.props;
---

<header
    class="w-full font-body text-sm"
    style="background-color: var(--gremius-color-primary, #03787C);"
>
    <div class="flex h-[48px] items-center justify-between px-3">
        {/* Left: Waffle + App Name */}
        <div class="flex items-center gap-4">
            <button
                class="flex h-12 w-12 items-center justify-center text-white hover:bg-black/10 transition-colors"
                aria-label="App Launcher"
            >
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                >
                    <circle cx="2.5" cy="2.5" r="2.5"></circle>
                    <circle cx="10" cy="2.5" r="2.5"></circle>
                    <circle cx="17.5" cy="2.5" r="2.5"></circle>
                    <circle cx="2.5" cy="10" r="2.5"></circle>
                    <circle cx="10" cy="10" r="2.5"></circle>
                    <circle cx="17.5" cy="10" r="2.5"></circle>
                    <circle cx="2.5" cy="17.5" r="2.5"></circle>
                    <circle cx="10" cy="17.5" r="2.5"></circle>
                    <circle cx="17.5" cy="17.5" r="2.5"></circle>
                </svg>
            </button>

            <a
                href="/"
                class="font-semibold text-white tracking-tight text-[16px] hover:underline decoration-white/50 underline-offset-4"
            >
                {siteName}
            </a>
        </div>

        {/* Center: Search Bar */}
        <div class="hidden md:flex flex-1 max-w-xl mx-4">
            <div class="relative w-full group">
                <div
                    class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"
                >
                    <svg
                        class="h-4 w-4 text-white/70 group-focus-within:text-black/60"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                        ></path>
                    </svg>
                </div>
                <input
                    type="text"
                    placeholder="Search across this site"
                    class="block w-full rounded-md border-none py-1.5 pl-10 pr-3 text-sm leading-5
                 bg-white/20 text-white placeholder-white/70
                 focus:outline-none focus:bg-white focus:text-gray-900 focus:placeholder-gray-500 focus:ring-0
                 transition-all duration-200 shadow-sm"
                />
            </div>
        </div>

        {/* Right: Actions + Avatar */}
        <div class="flex items-center gap-1">
            <button
                class="h-12 px-3 text-white hover:bg-black/10 flex items-center justify-center transition-colors"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                    ></path><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
                >
            </button>
            <button
                class="h-12 px-3 text-white hover:bg-black/10 flex items-center justify-center transition-colors"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path></svg
                >
            </button>

            <button
                class="ml-2 h-8 w-8 rounded-full overflow-hidden border-2 border-transparent hover:border-white/50 transition-all"
            >
                <img
                    src={userAvatar}
                    alt="User"
                    class="h-full w-full object-cover"
                />
            </button>
        </div>
    </div>
</header>
