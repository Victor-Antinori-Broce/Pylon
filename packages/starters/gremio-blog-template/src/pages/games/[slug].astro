---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlockRenderer from "../../components/blocks/BlockRenderer.astro";
import { cms } from "../../lib/cms";
import { gameJsonLd, formatDate } from "@gremius/shared";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/games");

const game = await cms.games.getBySlug(slug);
if (!game) return Astro.redirect("/games");

const jsonLd = gameJsonLd({
  title: game.title,
  description: game.excerpt || "",
  releaseDate: game.releaseDate,
  developer: game.developer,
  publisher: game.publisher,
  metacriticScore: game.metacriticScore,
  coverArt: game.coverArt as any,
});

const ogImage = (game.coverArt as any)?.sizes?.og?.url || (game.coverArt as any)?.url;

const scoreClass = game.metacriticScore
  ? game.metacriticScore >= 85 ? "text-green-400" : game.metacriticScore >= 70 ? "text-yellow-400" : "text-red-400"
  : "text-zinc-500";

// Extract blocks array (from JSONB column, defaults to empty)
const blocks = (game as any).blocks || [];
const hasBlocks = Array.isArray(blocks) && blocks.length > 0;
---

<BaseLayout
  title={game.title}
  description={game.excerpt || `${game.title} — Game info, stats, and more`}
  ogImage={ogImage}
  jsonLd={jsonLd}
  fullWidth
>
  <!-- Hero Cover -->
  <div class="relative h-[40vh] md:h-[50vh] overflow-hidden">
    {(game.coverArt as any)?.url ? (
      <img
        src={(game.coverArt as any).sizes?.hero?.url || (game.coverArt as any).url}
        alt={game.title}
        width="1920"
        height="800"
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-gremius-surface to-gremius-bg flex items-center justify-center">
        <span class="text-8xl opacity-10">🎮</span>
      </div>
    )}

    <!-- Gradient overlays -->
    <div class="absolute inset-0 bg-gradient-to-t from-gremius-bg via-gremius-bg/50 to-transparent" />
    <div class="absolute inset-0 bg-gradient-to-r from-gremius-bg/30 to-transparent" />

    <!-- Title overlay -->
    <div class="absolute bottom-0 inset-x-0 p-6 md:p-12">
      <div class="max-w-7xl mx-auto">
        <nav class="mb-4 flex items-center gap-2 text-sm text-zinc-500">
          <a href="/games" class="hover:text-gremius-cyan transition-colors">Games</a>
          <span class="text-zinc-700">›</span>
          <span class="text-gremius-text">{game.title}</span>
        </nav>

        <h1 class="font-display text-4xl font-bold text-gremius-heading md:text-6xl animate-enter">
          {game.title}
        </h1>

        <div class="mt-3 flex items-center gap-4 text-zinc-400 animate-enter animate-enter-delay-1">
          <span>{game.developer}</span>
          {game.publisher && game.publisher !== game.developer && (
            <>
              <span class="text-zinc-700">·</span>
              <span>{game.publisher}</span>
            </>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid gap-8 lg:grid-cols-3">
      <!-- Main Column -->
      <div class="lg:col-span-2 space-y-8">
        <!-- HUD Data Grid -->
        <div class="hud-grid grid-cols-2 md:grid-cols-4 animate-enter animate-enter-delay-2">
          <div class="hud-cell">
            <p class="text-[10px] font-display uppercase tracking-wider text-zinc-500 mb-1">Metacritic</p>
            <p class={`font-display text-2xl font-bold font-mono ${scoreClass}`}>
              {game.metacriticScore ?? "N/A"}
            </p>
          </div>
          <div class="hud-cell">
            <p class="text-[10px] font-display uppercase tracking-wider text-zinc-500 mb-1">Release</p>
            <p class="font-display text-sm font-semibold text-gremius-heading">
              {game.releaseDate
                ? formatDate(game.releaseDate, "en-US", { month: "short", day: "numeric", year: "numeric" })
                : "TBD"}
            </p>
          </div>
          <div class="hud-cell">
            <p class="text-[10px] font-display uppercase tracking-wider text-zinc-500 mb-1">Developer</p>
            <p class="font-display text-sm font-semibold text-gremius-heading truncate">{game.developer}</p>
          </div>
          <div class="hud-cell">
            <p class="text-[10px] font-display uppercase tracking-wider text-zinc-500 mb-1">Publisher</p>
            <p class="font-display text-sm font-semibold text-gremius-heading truncate">{game.publisher || "—"}</p>
          </div>
        </div>

        <!-- About -->
        {game.excerpt && (
          <div class="glass-card p-6 animate-enter animate-enter-delay-3">
            <h2 class="font-display text-lg font-semibold text-gremius-cyan mb-4">About</h2>
            <p class="text-zinc-300 leading-relaxed">{game.excerpt}</p>
          </div>
        )}

        <!--
          ═══ BLOCK RENDERER — "Lego" Custom Page Sections ═══
          Renders any blocks the admin placed via the Layout Builder.
          Appears between About and Screenshots.
        -->
        {hasBlocks && (
          <div class="animate-enter animate-enter-delay-3">
            <BlockRenderer blocks={blocks} />
          </div>
        )}

        <!-- Screenshots -->
        {game.screenshots && game.screenshots.length > 0 && (
          <div class="animate-enter animate-enter-delay-4">
            <h2 class="font-display text-lg font-semibold text-gremius-heading mb-4">Screenshots</h2>
            <div class="grid gap-3 sm:grid-cols-2">
              {game.screenshots.map((s: any) => {
                const img = s.image || s;
                return (
                  <div class="aspect-video overflow-hidden rounded-xl bg-gremius-surface border border-white/[0.06]">
                    <img
                      src={img.sizes?.card?.url || img.url}
                      alt={img.alt || `${game.title} screenshot`}
                      width="640"
                      height="360"
                      loading="lazy"
                      class="h-full w-full object-cover hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Platforms -->
        {game.platforms && game.platforms.length > 0 && (
          <div class="glass-card p-5 animate-enter animate-enter-delay-2">
            <h3 class="font-display text-[11px] font-semibold uppercase tracking-wider text-zinc-500 mb-3">Platforms</h3>
            <div class="flex flex-wrap gap-2">
              {game.platforms.map((p: any) => (
                <span class="inline-flex items-center rounded-xl bg-white/[0.04] border border-white/[0.06] px-3 py-1.5 text-xs font-medium text-zinc-300">
                  {typeof p === "string" ? p : p.shortName || p.name}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Tags -->
        {game.tags && game.tags.length > 0 && (
          <div class="glass-card p-5 animate-enter animate-enter-delay-3">
            <h3 class="font-display text-[11px] font-semibold uppercase tracking-wider text-zinc-500 mb-3">Tags</h3>
            <div class="flex flex-wrap gap-2">
              {game.tags.map((tag: any) => {
                const name = typeof tag === "string" ? tag : tag.name;
                const color = typeof tag === "object" && tag.color ? tag.color : "#00E5FF";
                return (
                  <span
                    class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border"
                    style={`color: ${color}; background: ${color}10; border-color: ${color}20;`}
                  >
                    {name}
                  </span>
                );
              })}
            </div>
          </div>
        )}

        <!-- Trailer -->
        {game.trailerUrl && (
          <div class="glass-card p-5 animate-enter animate-enter-delay-4">
            <h3 class="font-display text-[11px] font-semibold uppercase tracking-wider text-zinc-500 mb-3">Trailer</h3>
            <a
              href={game.trailerUrl}
              target="_blank"
              rel="noopener"
              class="gremius-btn-secondary w-full justify-center text-sm"
            >
              Watch Trailer ↗
            </a>
          </div>
        )}

        <!-- Edit link -->
        <div class="glass-card p-5">
          <a
            href={`http://localhost:5173/games`}
            class="gremius-btn-ghost w-full justify-center text-xs text-zinc-500"
          >
            Edit in Admin →
          </a>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
