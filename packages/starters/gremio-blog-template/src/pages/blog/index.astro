---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cms } from "../../lib/cms";

let posts: any[] = [];
try {
  const res = await cms.posts.list({ limit: 20 });
  posts = res.docs || [];
} catch {
  posts = [
    {
      id: "1",
      title: "Welcome to GremiusCMS",
      slug: "welcome-to-gremiuscms",
      excerpt: "Introducing GremiusCMS — the high-performance gaming CMS.",
      publishedAt: "2025-02-10",
      author: { displayName: "Admin" },
      tags: [{ name: "Announcement", color: "#00E5FF" }],
      readingTime: 3,
    },
  ];
}
---

<BaseLayout
  title="Blog"
  description="Gaming news, guides, reviews, and opinion pieces"
>
  <section class="py-12">
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-1 w-8 bg-gremius-pink rounded-full"></div>
        <p
          class="font-display text-[11px] font-semibold uppercase tracking-[0.2em] text-gremius-pink"
        >
          Content
        </p>
      </div>
      <h1
        class="font-display text-4xl font-bold text-gremius-heading md:text-5xl"
      >
        Latest Posts
      </h1>
      <p class="mt-3 text-zinc-500 text-lg">
        News, guides, and deep dives into the games that matter
      </p>
    </div>

    {
      posts.length > 0 ? (
        <div class="grid gap-6 lg:grid-cols-2">
          {posts.map((post: any, idx: number) => (
            <a
              href={`/blog/${post.slug}`}
              class:list={[
                "glass-card group block overflow-hidden animate-enter",
                idx === 0 && "lg:col-span-2",
              ]}
              style={`animation-delay: ${idx * 0.08}s`}
            >
              <div
                class:list={[
                  "flex gap-0",
                  idx === 0 ? "flex-col md:flex-row" : "flex-col",
                ]}
              >
                {post.featuredImage?.url && (
                  <div
                    class:list={[
                      "overflow-hidden shrink-0",
                      idx === 0 ? "aspect-video md:w-1/2" : "aspect-video",
                    ]}
                  >
                    <img
                      src={
                        post.featuredImage.sizes?.card?.url ||
                        post.featuredImage.url
                      }
                      alt={post.featuredImage.alt || post.title}
                      width="640"
                      height="360"
                      loading={idx < 2 ? "eager" : "lazy"}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  </div>
                )}
                <div class="flex flex-1 flex-col justify-center p-6 md:p-8">
                  {post.tags?.length > 0 && (
                    <div class="mb-3 flex gap-2">
                      {post.tags.slice(0, 3).map((tag: any) => {
                        const name = typeof tag === "string" ? tag : tag.name;
                        const color =
                          typeof tag === "object" && tag.color
                            ? tag.color
                            : "#FF2A6D";
                        return (
                          <span
                            class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wider border"
                            style={`color: ${color}; background: ${color}10; border-color: ${color}20;`}
                          >
                            {name}
                          </span>
                        );
                      })}
                    </div>
                  )}
                  <h2
                    class:list={[
                      "font-display font-bold text-gremius-heading group-hover:text-gremius-pink transition-colors leading-tight",
                      idx === 0 ? "text-2xl md:text-3xl" : "text-xl",
                    ]}
                  >
                    {post.title}
                  </h2>
                  {post.excerpt && (
                    <p class="mt-3 text-sm leading-relaxed text-zinc-500 line-clamp-2">
                      {post.excerpt}
                    </p>
                  )}
                  <div class="mt-5 flex items-center gap-3 text-[11px] text-zinc-600">
                    {post.author?.displayName && (
                      <span>{post.author.displayName}</span>
                    )}
                    {post.publishedAt && (
                      <span>
                        {new Date(post.publishedAt).toLocaleDateString(
                          "en-US",
                          { month: "short", day: "numeric", year: "numeric" },
                        )}
                      </span>
                    )}
                    {post.readingTime && (
                      <span>· {post.readingTime} min read</span>
                    )}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="glass-card p-20 text-center">
          <span class="text-5xl mb-4 block">📝</span>
          <p class="text-zinc-500 mb-4">
            No posts yet. Stay tuned for updates!
          </p>
        </div>
      )
    }
  </section>
</BaseLayout>
