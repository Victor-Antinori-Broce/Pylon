---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/islands/Hero.vue";
import DynamicBackground from "../components/islands/DynamicBackground.vue";
import GameSection from "../components/games/GameSection.astro";
import { cms } from "../lib/cms";

// Fetch curated collections (each has .games[] populated)
let collections: any[] = [];
try {
  const res = await cms.collections.list();
  collections = (res.docs || []).filter((c: any) => c.games?.length > 0);
} catch (err) {
  console.error("Failed to fetch collections:", err);
  // API down — show empty
}

// Fetch recent posts
let posts: any[] = [];
try {
  const res = await cms.posts.list({ limit: 3 });
  posts = res.docs || [];
} catch (err) {
  console.error("Failed to fetch posts:", err);
  posts = [
    {
      id: "1",
      title: "Welcome to GremiusCMS",
      slug: "welcome-to-gremiuscms",
      excerpt: "Introducing GremiusCMS — the high-performance gaming CMS.",
      publishedAt: "2025-02-10",
      author: { displayName: "Admin" },
    },
  ];
}
---

<BaseLayout
  title="Home"
  description="GremiusCMS — The High-Performance Open Source Gaming CMS"
  fullWidth
>
  <!-- Dynamic hovering background (fixed, behind everything) -->
  <DynamicBackground client:load />

  <!-- Hero (Vue Island with entry animations) -->
  <Hero client:load />

  <!-- Gradient divider -->
  <div class="gradient-divider mx-6"></div>

  <!-- ═══ BLOG PREVIEW ═══ -->
  {
    posts.length > 0 && (
      <section class="mx-auto max-w-7xl px-6 py-20 relative z-[1]">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="font-display text-[11px] font-semibold uppercase tracking-[0.2em] text-gremius-pink mb-2">
              Content
            </p>
            <h2 class="font-display text-3xl font-bold text-gremius-heading md:text-4xl">
              Latest Posts
            </h2>
          </div>
          <a href="/blog" class="gremius-btn-ghost text-sm group">
            View all
            <svg
              class="w-4 h-4 transition-transform group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"
              />
            </svg>
          </a>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {posts.map((post: any, i: number) => (
            <a
              href={`/blog/${post.slug}`}
              class="glass-card group block p-6 animate-enter"
              style={`animation-delay: ${i * 0.1}s`}
            >
              {post.tags?.length > 0 && (
                <div class="flex gap-2 mb-3">
                  {post.tags.slice(0, 2).map((tag: any) => (
                    <span class="gremius-badge-pink text-[10px]">
                      {typeof tag === "string" ? tag : tag.name}
                    </span>
                  ))}
                </div>
              )}
              <h3 class="font-display text-lg font-semibold text-gremius-heading group-hover:text-gremius-pink transition-colors leading-tight">
                {post.title}
              </h3>
              {post.excerpt && (
                <p class="mt-2 text-sm text-zinc-500 line-clamp-2 leading-relaxed">
                  {post.excerpt}
                </p>
              )}
              <div class="mt-4 flex items-center gap-3 text-[11px] text-zinc-600">
                {post.author?.displayName && (
                  <span>{post.author.displayName}</span>
                )}
                {post.publishedAt && (
                  <span>
                    {new Date(post.publishedAt).toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- ═══ CURATED GAME COLLECTIONS ═══ -->
  {
    collections.length > 0 && (
      <div class="collections-wrapper mx-auto max-w-7xl py-8 relative z-[1]">
        {collections.map((col: any) => (
          <GameSection title={col.title} games={col.games} />
        ))}
      </div>
    )
  }

  <!-- Empty state if no collections -->
  {
    collections.length === 0 && (
      <section class="mx-auto max-w-7xl px-6 py-16 relative z-[1]">
        <div class="glass-card p-16 text-center">
          <p class="text-gremius-text-dim">No game collections yet.</p>
        </div>
      </section>
    )
  }

  <!-- ═══ CTA Section ═══ -->
  <section class="mx-auto max-w-7xl px-6 py-20 relative z-[1]">
    <div class="glass-card p-12 md:p-16 text-center relative overflow-hidden">
      <!-- Background glow -->
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(0,229,255,0.04)_0%,_transparent_70%)]"
      >
      </div>

      <div class="relative z-10">
        <h2
          class="font-display text-3xl font-bold text-gremius-heading md:text-4xl"
        >
          Open Source. <span class="text-gradient">Open Meta.</span>
        </h2>
        <p class="mt-4 text-zinc-400 max-w-lg mx-auto leading-relaxed">
          GremiusCMS is free and open source. Built with Astro, Hono, and Vue —
          the modern stack for gaming communities.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a href="https://github.com/gremiuscms" class="gremius-btn-primary">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
              ></path></svg
            >
            Star on GitHub
          </a>
          <a href="/games" class="gremius-btn-secondary">Explore Database</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
