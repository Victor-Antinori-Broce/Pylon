# ═══════════════════════════════════════════════
# GremiusCMS - Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# ── Database ──
POSTGRES_DB=gremiuscms
POSTGRES_USER=gremius
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgres://gremius:change_me_in_production@localhost:5432/gremiuscms

# ── S3 / MinIO ──
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=gremius-media
S3_ACCESS_KEY=gremius_minio
S3_SECRET_KEY=change_me_in_production
S3_PUBLIC_URL=http://localhost:9000
S3_REGION=us-east-1

# ── Valkey (Redis-compatible cache & queues) ──
VALKEY_URL=redis://localhost:6379

# ── API ──
API_PORT=3001
JWT_SECRET=change_me_in_production
ADMIN_URL=http://localhost:5173

# ── CORS ──
# Comma-separated list of allowed origins for API requests
# Example: ALLOWED_ORIGINS=http://localhost:4321,http://localhost:5173,https://mydomain.com
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:5173,http://gremius_web:4321,http://gremius_admin:80

# ── Frontend ──
WEB_PORT=4321
PUBLIC_API_URL=http://localhost:3001
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_SITE_NAME=GremiusCMS

# ── Admin ──
ADMIN_PORT=5173

# ── SMTP / Email (OPTIONAL — runs in Mock Mode if missing) ──
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
# SMTP_FROM=GremiusCMS <noreply@yourdomain.com>
# SMTP_SECURE=false

# ── External APIs (optional) ──
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
YOUTUBE_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# OAuth Providers (Social & Enterprise)
# ═══════════════════════════════════════════════════════════════════════════

# ── GitHub (Developer Login) ──
# Create app at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3001/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google (General User Login) ──
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft Azure AD (Enterprise/B2B Login) ──
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Redirect URI: http://localhost:3001/api/auth/callback/microsoft
# Use 'common' for multi-tenant, or specific tenant ID for single-tenant
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
